/**
 * 通用组件样式
 */

/* ==================== 卡片组件 ==================== */

.card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.card-padding {
  padding: 24rpx;
}

.card-padding-lg {
  padding: 32rpx;
}

/* ==================== 按钮组件 ==================== */

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  transition: all 0.2s ease;
}

.btn-primary {
  background-color: #4A90E2;
  color: #FFFFFF;
}

.btn-secondary {
  background-color: #FFFFFF;
  color: #1A1A1A;
  border: 2rpx solid #E5E5E5;
}

.btn-ghost {
  background-color: transparent;
  color: #1A1A1A;
}

/* ==================== 输入框组件 ==================== */

.input {
  width: 100%;
  padding: 16rpx 24rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 16rpx;
  font-size: 32rpx;
  background-color: #FFFFFF;
  color: #1A1A1A;
  box-sizing: border-box;
}

.input:focus {
  border-color: #4A90E2;
  outline: none;
}

/* ==================== 文本组件 ==================== */

.text-h1 {
  font-size: 48rpx;
  font-weight: 600;
  color: #1A1A1A;
  line-height: 1.2;
}

.text-h2 {
  font-size: 40rpx;
  font-weight: 600;
  color: #1A1A1A;
  line-height: 1.3;
}

.text-h3 {
  font-size: 36rpx;
  font-weight: 500;
  color: #1A1A1A;
  line-height: 1.4;
}

.text-body {
  font-size: 32rpx;
  color: #1A1A1A;
  line-height: 1.5;
}

.text-caption {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.4;
}

.text-secondary {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.3;
}
