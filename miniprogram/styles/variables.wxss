/**
 * 极简设计系统 - 设计变量
 * 基于 Pixso 设计稿提取
 */

/* ==================== 颜色系统 ==================== */

/* 主色调 - 纯色（无渐变） */
--color-primary: #4A90E2;        /* 主蓝色 */
--color-primary-light: #EBF3FB;  /* 浅蓝背景 */

/* 中性色 */
--color-bg-primary: #FFFFFF;     /* 主背景 */
--color-bg-secondary: #F5F7FA;   /* 次级背景 */
--color-bg-tertiary: #FAFAFA;    /* 三级背景 */

/* 文字颜色 */
--color-text-primary: #1A1A1A;   /* 主文字 */
--color-text-secondary: #666666; /* 次要文字 */
--color-text-tertiary: #999999;  /* 辅助文字 */

/* 边框颜色 */
--color-border: #E5E5E5;
--color-divider: #EEEEEE;

/* 功能色 */
--color-success: #52C41A;        /* 成功绿 */
--color-error: #F5222D;          /* 错误红 */
--color-warning: #FAAD14;        /* 警告黄 */

/* ==================== 字体系统 ==================== */

/* 字号 */
--font-size-h1: 48rpx;           /* 一级标题 */
--font-size-h2: 40rpx;           /* 二级标题 */
--font-size-h3: 36rpx;           /* 三级标题 */
--font-size-body: 32rpx;         /* 正文 */
--font-size-caption: 28rpx;      /* 说明文字 */
--font-size-secondary: 24rpx;    /* 次要文字 */

/* 字重 */
--font-weight-regular: 400;
--font-weight-medium: 500;
--font-weight-bold: 600;

/* ==================== 间距系统 ==================== */

/* 基础间距单位：8rpx */
--spacing-xs: 8rpx;
--spacing-sm: 16rpx;
--spacing-md: 24rpx;
--spacing-lg: 32rpx;
--spacing-xl: 48rpx;
--spacing-xxl: 64rpx;

/* ==================== 圆角系统 ==================== */

--radius-sm: 8rpx;
--radius-md: 12rpx;
--radius-lg: 16rpx;
--radius-xl: 24rpx;
--radius-round: 50%;

/* ==================== 阴影系统 ==================== */

/* 极简阴影（更轻柔） */
--shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
--shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
--shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);

/* ==================== 层级系统 ==================== */

--z-index-base: 1;
--z-index-overlay: 100;
--z-index-modal: 200;
--z-index-toast: 300;
