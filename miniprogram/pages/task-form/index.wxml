<!-- 新增任务页面 -->
<view class="container">
  <view class="form" role="form" aria-label="创建新任务">
    <!-- 标题输入区 -->
    <view class="form-item">
      <text class="label">标题</text>
      <view class="title-row">
        <input
          class="title-input"
          placeholder="输入任务标题..."
          value="{{title}}"
          bindinput="onTitleInput"
          maxlength="50"
          aria-label="任务标题输入框"
          required
        />
        <picker
          mode="selector"
          range="{{priorityOptions}}"
          bindchange="onPriorityChange"
          value="{{priorityIndex}}"
          class="priority-selector"
          aria-label="优先级选择器"
        >
          <view class="priority-picker">
            <text class="priority-dot-{{priority}}"></text>
            <text class="priority-label">{{priorityLabel}}</text>
          </view>
        </picker>
      </view>
      <text class="counter" aria-label="已输入{{title.length}}字，最多50字">{{title.length}}/50</text>
    </view>

    <!-- 内容输入区 -->
    <view class="form-item">
      <text class="label">内容</text>
      <textarea
        class="content-input"
        placeholder="输入详细内容...（可选）"
        value="{{content}}"
        bindinput="onContentInput"
        maxlength="500"
        auto-height
        aria-label="任务内容输入框"
      />
      <text class="counter" aria-label="已输入{{content.length}}字，最多500字">{{content.length}}/500</text>
    </view>
  </view>

  <view class="actions">
    <button
      class="cancel-button"
      bindtap="handleCancel"
      aria-label="取消创建"
    >
      取消
    </button>
    <button
      class="save-button {{isSubmitting ? 'disabled' : ''}}"
      bindtap="handleSave"
      disabled="{{isSubmitting}}"
      aria-label="保存任务"
    >
      保存
    </button>
  </view>
</view>
