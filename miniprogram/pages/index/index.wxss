/**
 * TodoList 首页样式 - Apple 风格
 */

/* ==================== 页面基础 ==================== */

.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #e8f0f8 0%, #d4e4f4 50%, #c9d9ec 100%);
  display: flex;
  justify-content: center;
  padding: 80rpx 40rpx;
  box-sizing: border-box;
  transition: background 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow-x: hidden;
}

/* 背景装饰元素 */
.page::before {
  content: '';
  position: fixed;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background:
    radial-gradient(ellipse at 20% 20%, rgba(120, 180, 255, 0.15) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 80%, rgba(200, 160, 255, 0.12) 0%, transparent 50%),
    radial-gradient(ellipse at 60% 30%, rgba(255, 200, 180, 0.1) 0%, transparent 40%);
  pointer-events: none;
  z-index: 0;
}

/* 暗色模式 */
.page.dark {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}

/* 容器 */
.container {
  display: flex;
  flex-direction: column;
  width: 100%;
  max-width: 780rpx;
  position: relative;
  z-index: 1;
}

/* 毛玻璃卡片效果 */
.glass-card {
  width: 100%;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.65);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: 48rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.08), 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  padding: 64rpx 56rpx;
  position: relative;
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.glass-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.6), transparent);
}

.page.dark .glass-card {
  width: 100%;
  box-sizing: border-box;
  background: rgba(30, 30, 50, 0.7);
  border-color: rgba(255, 255, 255, 0.15);
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
}

.page.dark .glass-card::before {
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.15), transparent);
}

/* ==================== 头部 ==================== */

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 56rpx;
  padding-bottom: 40rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.page.dark .header {
  border-bottom-color: rgba(255, 255, 255, 0.08);
}

.title-group {
  position: relative;
}

.title {
  font-size: 64rpx;
  font-weight: 600;
  color: #1d1d1f;
  letter-spacing: -1rpx;
}

.page.dark .title {
  color: #f5f5f7;
}

.subtitle {
  font-size: 26rpx;
  font-weight: 400;
  color: #86868b;
  margin-top: 8rpx;
  display: block;
}

.page.dark .subtitle {
  color: #a1a1a6;
}

/* 主题切换按钮 */
.theme-toggle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  padding: 0;
  position: relative;
}

.theme-toggle:hover {
  transform: scale(1.05);
  background: rgba(255, 255, 255, 0.8);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.page.dark .theme-toggle {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.12);
}

.page.dark .theme-toggle:hover {
  background: rgba(255, 255, 255, 0.18);
}

.sun-icon,
.moon-icon {
  width: 40rpx;
  height: 40rpx;
  position: absolute;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.sun-icon {
  color: #ff9500;
}

.moon-icon {
  color: #5e5ce6;
  opacity: 0;
  transform: rotate(-90deg) scale(0.5);
}

.page.dark .sun-icon {
  opacity: 0;
  transform: rotate(90deg) scale(0.5);
}

.page.dark .moon-icon {
  opacity: 1;
  transform: rotate(0deg) scale(1);
}

/* ==================== 统计卡片 ==================== */

.stats {
  display: flex;
  gap: 32rpx;
  margin-bottom: 48rpx;
}

.stat-item {
  flex: 1;
  padding: 32rpx;
  border-radius: 32rpx;
  background: rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
}

.page.dark .stat-item {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.08);
}

.stat-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.page.dark .stat-value {
  color: #f5f5f7;
}

.stat-label {
  font-size: 24rpx;
  color: #86868b;
  margin-top: 4rpx;
}

.page.dark .stat-label {
  color: #a1a1a6;
}

/* ==================== 任务列表 ==================== */

.task-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  min-height: 200rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #86868b;
}

.page.dark .empty-text {
  color: #a1a1a6;
}

.empty-subtext {
  font-size: 26rpx;
  color: #aeaeb2;
  margin-top: 8rpx;
}

.page.dark .empty-subtext {
  color: #636366;
}

/* 任务项 */
.task-item {
  display: flex;
  align-items: center;
  padding: 32rpx 36rpx;
  border-radius: 28rpx;
  cursor: pointer;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  background: transparent;
  margin: 0 -8rpx;
}

.task-item:hover {
  background: rgba(0, 0, 0, 0.03);
}

.page.dark .task-item:hover {
  background: rgba(255, 255, 255, 0.05);
}

/* 复选框 */
.checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(0, 0, 0, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  flex-shrink: 0;
  position: relative;
}

.page.dark .checkbox {
  border-color: rgba(255, 255, 255, 0.2);
}

.checkbox::after {
  content: '';
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #007aff;
  transform: scale(0);
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.page.dark .checkbox::after {
  background: #0a84ff;
}

.task-item.completed .checkbox {
  border-color: #007aff;
  background: #007aff;
}

.page.dark .task-item.completed .checkbox {
  border-color: #0a84ff;
  background: #0a84ff;
}

.task-item.completed .checkbox::after {
  transform: scale(1);
}

/* 任务内容 */
.task-content {
  flex: 1;
  margin-left: 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.task-text {
  font-size: 30rpx;
  font-weight: 400;
  color: #1d1d1f;
  transition: all 0.25s ease;
}

.page.dark .task-text {
  color: #f5f5f7;
}

.task-item.completed .task-text {
  color: #86868b;
  text-decoration: line-through;
  text-decoration-color: rgba(0, 0, 0, 0.3);
}

.page.dark .task-item.completed .task-text {
  color: #a1a1a6;
  text-decoration-color: rgba(255, 255, 255, 0.3);
}

/* 任务标签 */
.task-tag {
  font-size: 20rpx;
  font-weight: 500;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  text-transform: uppercase;
  letter-spacing: 0.6rpx;
}

.tag-work {
  background: rgba(255, 149, 0, 0.15);
  color: #ff9500;
}

.page.dark .tag-work {
  background: rgba(255, 149, 0, 0.2);
}

.tag-personal {
  background: rgba(0, 122, 255, 0.12);
  color: #007aff;
}

.page.dark .tag-personal {
  background: rgba(10, 132, 255, 0.2);
}

.tag-default {
  background: rgba(142, 142, 147, 0.12);
  color: #8e8e93;
}

.page.dark .tag-default {
  background: rgba(142, 142, 147, 0.2);
}

/* 优先级指示器 */
.task-priority {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.priority-high {
  background: #ff3b30;
  box-shadow: 0 0 16rpx rgba(255, 59, 48, 0.4);
}

.priority-medium {
  background: #ff9500;
  box-shadow: 0 0 16rpx rgba(255, 149, 0, 0.4);
}

.priority-low {
  background: #34c759;
  box-shadow: 0 0 16rpx rgba(52, 199, 89, 0.4);
}

/* ==================== 添加任务按钮 ==================== */

.add-task-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  padding: 32rpx;
  margin-top: 32rpx;
  border-radius: 28rpx;
  border: 1rpx dashed rgba(0, 0, 0, 0.15);
  background: rgba(0, 0, 0, 0.02);
  color: #86868b;
  font-size: 28rpx;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.25s ease;
  position: relative;
  overflow: hidden;
}

.add-task-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  transition: width 0.4s ease, height 0.4s ease;
}

.add-task-btn:active::after {
  width: 400rpx;
  height: 400rpx;
}

.add-task-btn:hover {
  background: rgba(0, 0, 0, 0.05);
  border-color: rgba(0, 0, 0, 0.2);
  color: #1d1d1f;
}

.page.dark .add-task-btn {
  border-color: rgba(255, 255, 255, 0.15);
  background: rgba(255, 255, 255, 0.03);
  color: #a1a1a6;
}

.page.dark .add-task-btn::after {
  background: rgba(255, 255, 255, 0.1);
}

.page.dark .add-task-btn:hover {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.25);
  color: #f5f5f7;
}

.add-task-btn svg {
  width: 32rpx;
  height: 32rpx;
}

.add-task-btn svg path {
  stroke: currentColor;
}
