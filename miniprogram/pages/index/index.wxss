/**
 * TodoList 首页样式 - Apple 风格
 */

/* ==================== 页面基础 ==================== */

.page {
  height: 100vh;
  background: linear-gradient(135deg, #e8f0f8 0%, #d4e4f4 50%, #c9d9ec 100%);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  transition: background 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  padding: 40rpx;
}

/* 背景装饰元素 */
.page::before {
  content: '';
  position: fixed;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background:
    radial-gradient(ellipse at 20% 20%, rgba(120, 180, 255, 0.15) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 80%, rgba(200, 160, 255, 0.12) 0%, transparent 50%),
    radial-gradient(ellipse at 60% 30%, rgba(255, 200, 180, 0.1) 0%, transparent 40%);
  pointer-events: none;
  z-index: 0;
}

/* 暗色模式 */
.page.dark {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}

/* ==================== 固定顶部区域 ==================== */

.fixed-header {
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.65);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08), 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  padding: 40rpx;
  position: relative;
  z-index: 1;
}

.fixed-header::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.6), transparent);
  border-radius: 40rpx 40rpx 0 0;
}

.page.dark .fixed-header {
  background: rgba(30, 30, 50, 0.7);
  border-color: rgba(255, 255, 255, 0.15);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
}

.page.dark .fixed-header::before {
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.15), transparent);
}

/* 头部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.title-group {
  position: relative;
}

.title {
  font-size: 56rpx;
  font-weight: 600;
  color: #1d1d1f;
  letter-spacing: -1rpx;
}

.page.dark .title {
  color: #f5f5f7;
}

.subtitle {
  font-size: 24rpx;
  font-weight: 400;
  color: #86868b;
  margin-top: 8rpx;
  display: block;
}

.page.dark .subtitle {
  color: #a1a1a6;
}

/* 主题切换按钮 */
.theme-toggle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}

.theme-toggle:hover {
  transform: scale(1.05);
  background: rgba(255, 255, 255, 0.8);
}

.page.dark .theme-toggle {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.12);
}

/* 太阳图标 */
.sun-icon {
  width: 36rpx;
  height: 36rpx;
  position: relative;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.sun-core {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 14rpx;
  height: 14rpx;
  background: #ff9500;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 0 10rpx rgba(255, 149, 0, 0.6);
}

.sun-ray {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 3rpx;
  height: 8rpx;
  background: #ff9500;
  border-radius: 2rpx;
  transform-origin: center bottom;
}

.sun-ray-1 { transform: translate(-50%, -100%) rotate(0deg) translateY(-10rpx); }
.sun-ray-2 { transform: translate(-50%, -100%) rotate(45deg) translateY(-10rpx); }
.sun-ray-3 { transform: translate(-50%, -100%) rotate(90deg) translateY(-10rpx); }
.sun-ray-4 { transform: translate(-50%, -100%) rotate(135deg) translateY(-10rpx); }
.sun-ray-5 { transform: translate(-50%, -100%) rotate(180deg) translateY(-10rpx); }
.sun-ray-6 { transform: translate(-50%, -100%) rotate(225deg) translateY(-10rpx); }
.sun-ray-7 { transform: translate(-50%, -100%) rotate(270deg) translateY(-10rpx); }
.sun-ray-8 { transform: translate(-50%, -100%) rotate(315deg) translateY(-10rpx); }

/* 月亮图标 */
.moon-icon {
  position: absolute;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #5e5ce6;
  box-shadow: inset -6rpx -3rpx 0 0 rgba(0, 0, 0, 0.2);
  opacity: 0;
  transform: rotate(-90deg) scale(0.5);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 暗色模式切换 */
.page.dark .sun-icon {
  opacity: 0;
  transform: rotate(90deg) scale(0.5);
}

.page.dark .moon-icon {
  opacity: 1;
  transform: rotate(0deg) scale(1);
}

/* ==================== 统计卡片 ==================== */

.stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  flex: 1;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
}

.page.dark .stat-item {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.08);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.page.dark .stat-value {
  color: #f5f5f7;
}

.stat-label {
  font-size: 22rpx;
  color: #86868b;
  margin-top: 4rpx;
}

.page.dark .stat-label {
  color: #a1a1a6;
}

/* ==================== 任务列表容器 ==================== */

.task-container {
  flex: 1;
  margin-top: 24rpx;
  background: rgba(255, 255, 255, 0.65);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08), 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.page.dark .task-container {
  background: rgba(30, 30, 50, 0.7);
  border-color: rgba(255, 255, 255, 0.15);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
}

/* 可滚动任务列表 */
.task-scroll {
  height: 100%;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #86868b;
}

.page.dark .empty-text {
  color: #a1a1a6;
}

.empty-subtext {
  font-size: 24rpx;
  color: #aeaeb2;
  margin-top: 8rpx;
  text-align: center;
}

.page.dark .empty-subtext {
  color: #636366;
}

/* 任务项 */
.task-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-radius: 24rpx;
  cursor: pointer;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  background: rgba(255, 255, 255, 0.6);
}

.task-item:hover {
  background: rgba(255, 255, 255, 0.9);
}

.page.dark .task-item {
  background: rgba(255, 255, 255, 0.08);
}

.page.dark .task-item:hover {
  background: rgba(255, 255, 255, 0.15);
}

/* 复选框 */
.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(0, 0, 0, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  flex-shrink: 0;
  position: relative;
}

.page.dark .checkbox {
  border-color: rgba(255, 255, 255, 0.2);
}

.checkbox::after {
  content: '';
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #007aff;
  transform: scale(0);
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.page.dark .checkbox::after {
  background: #0a84ff;
}

.task-item.completed .checkbox {
  border-color: #007aff;
  background: #007aff;
}

.page.dark .task-item.completed .checkbox {
  border-color: #0a84ff;
  background: #0a84ff;
}

.task-item.completed .checkbox::after {
  transform: scale(1);
}

/* 任务内容 */
.task-content {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.task-text {
  font-size: 28rpx;
  font-weight: 400;
  color: #1d1d1f;
  transition: all 0.25s ease;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.page.dark .task-text {
  color: #f5f5f7;
}

.task-item.completed .task-text {
  color: #86868b;
  text-decoration: line-through;
  text-decoration-color: rgba(0, 0, 0, 0.3);
}

.page.dark .task-item.completed .task-text {
  color: #a1a1a6;
  text-decoration-color: rgba(255, 255, 255, 0.3);
}

/* 任务标签 */
.task-tag {
  font-size: 18rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  text-transform: uppercase;
  letter-spacing: 0.4rpx;
  flex-shrink: 0;
}

.tag-work {
  background: rgba(255, 149, 0, 0.15);
  color: #ff9500;
}

.page.dark .tag-work {
  background: rgba(255, 149, 0, 0.2);
}

.tag-personal {
  background: rgba(0, 122, 255, 0.12);
  color: #007aff;
}

.page.dark .tag-personal {
  background: rgba(10, 132, 255, 0.2);
}

.tag-default {
  background: rgba(142, 142, 147, 0.12);
  color: #8e8e93;
}

.page.dark .tag-default {
  background: rgba(142, 142, 147, 0.2);
}

/* 优先级指示器 */
.task-priority {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.priority-high {
  background: #ff3b30;
  box-shadow: 0 0 12rpx rgba(255, 59, 48, 0.4);
}

.priority-medium {
  background: #ff9500;
  box-shadow: 0 0 12rpx rgba(255, 149, 0, 0.4);
}

.priority-low {
  background: #34c759;
  box-shadow: 0 0 12rpx rgba(52, 199, 89, 0.4);
}

/* ==================== 悬浮添加按钮 (FAB) ==================== */

.fab-button {
  position: fixed;
  right: 56rpx;
  bottom: 56rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #007aff, #0051d4);
  box-shadow: 0 8rpx 32rpx rgba(0, 122, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 100;
}

.fab-button:hover {
  transform: scale(1.1);
  box-shadow: 0 12rpx 40rpx rgba(0, 122, 255, 0.5);
}

.fab-button:active {
  transform: scale(0.95);
}

.fab-button.dark {
  background: linear-gradient(135deg, #0a84ff, #0066cc);
  box-shadow: 0 8rpx 32rpx rgba(10, 132, 255, 0.4);
}

/* FAB 图标 - 加号 */
.fab-icon {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.fab-icon::before,
.fab-icon::after {
  content: '';
  position: absolute;
  background: #ffffff;
  border-radius: 4rpx;
}

.fab-icon::before {
  width: 44rpx;
  height: 6rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.fab-icon::after {
  width: 6rpx;
  height: 44rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}
