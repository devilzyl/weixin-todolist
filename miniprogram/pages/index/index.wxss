/**
 * TodoList 列表页样式
 */

page {
  height: 100vh;
  background-color: #f5f5f5;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* 统计卡片容器 */
.stats-container {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  overflow-x: auto;
}

/* 统计卡片 */
.stat-card {
  flex: 1;
  min-width: 200rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.stat-card.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.stat-card.success {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #fff;
}

.stat-card.warning {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: #fff;
}

/* 统计图标 */
.stat-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  font-size: 28rpx;
}

/* 统计内容 */
.stat-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.9;
}

/* 快速创建区 */
.quick-create {
  margin: 16rpx 24rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.quick-input-wrapper {
  position: relative;
  margin-bottom: 16rpx;
}

.quick-input {
  width: 100%;
  padding: 16rpx;
  padding-right: 80rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background-color: #f9fafb;
  transition: all 0.3s ease;
}

.quick-input:focus {
  border-color: #667eea;
  background-color: #fff;
}

.quick-counter {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 22rpx;
  color: #9ca3af;
}

.quick-actions {
  display: flex;
  gap: 12rpx;
}

.quick-btn {
  flex: 1;
  padding: 20rpx 16rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.quick-btn::after {
  border: none;
}

.quick-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
}

.quick-btn.primary:active {
  transform: scale(0.96);
  box-shadow: 0 1rpx 4rpx rgba(102, 126, 234, 0.3);
}

.quick-btn.secondary {
  background: #fff;
  color: #6b7280;
  border: 2rpx solid #e5e7eb;
}

.quick-btn.secondary:active {
  transform: scale(0.96);
  background: #f9fafb;
}

.quick-btn[disabled] {
  opacity: 0.5;
  background: #d1d5db;
  color: #9ca3af;
  box-shadow: none;
}

/* 批量操作栏 */
.batch-actions {
  display: flex;
  gap: 12rpx;
  padding: 0 24rpx 16rpx;
}

.batch-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 12rpx;
  border-radius: 12rpx;
  background: #fff;
  border: 2rpx solid #e5e7eb;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.2s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.batch-btn::after {
  border: none;
}

.batch-btn:active {
  transform: scale(0.96);
}

.batch-btn[disabled] {
  opacity: 0.5;
  background: #f9fafb;
}

.batch-btn .btn-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.batch-btn .btn-text {
  font-size: 22rpx;
  color: #6b7280;
}

.batch-btn.complete-all {
  background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
  border-color: #10b981;
}

.batch-btn.uncomplete-all {
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  border-color: #3b82f6;
}

.batch-btn.clear-completed {
  background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
  border-color: #ef4444;
}

.batch-btn.clear-completed[disabled] {
  border-color: #e5e7eb;
  opacity: 0.4;
}

/* 任务列表 */
.todo-list {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx;
}

/* 空态容器 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
  animation: fadeIn 0.5s ease;
}

/* 空态插画 */
.empty-illustration {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}

.illustration-circle {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  opacity: 0.1;
  animation: pulse 2s ease-in-out infinite;
}

.illustration-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 80rpx;
  animation: float 3s ease-in-out infinite;
}

/* 空态文字 */
.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 40rpx;
  text-align: center;
}

/* 空态操作按钮 */
.empty-action {
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.empty-action:active {
  transform: scale(0.95);
}

.action-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

/* 任务项 */
.todo-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.todo-item:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

/* 完成状态 */
.todo-item.completed {
  opacity: 0.6;
  background: #f9fafb;
}

.todo-item.completed .todo-title {
  text-decoration: line-through;
  color: #9ca3af;
}

/* 新增高亮状态 */
.todo-item.is-new {
  animation: newHighlight 0.8s ease-out;
  background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
  border: 2rpx solid #10b981;
}

@keyframes newHighlight {
  0% {
    transform: scale(0.95);
    opacity: 0.5;
  }
  50% {
    transform: scale(1.02);
    opacity: 1;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 左侧区域 */
.todo-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

/* 自定义复选框 */
.custom-checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #e5e7eb;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.custom-checkbox.checked {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-color: transparent;
  transform: scale(1.1);
}

.checkbox-inner {
  animation: checkPop 0.3s ease-out;
}

.check-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* 任务内容 */
.todo-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}

.todo-title {
  font-size: 30rpx;
  color: #1f2937;
  line-height: 1.5;
  word-break: break-all;
}

/* 操作按钮组 */
.action-buttons {
  display: flex;
  gap: 8rpx;
  align-items: center;
}

/* 编辑按钮 */
.edit-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.edit-btn-hover {
  background: #f0f9ff;
  transform: scale(1.1);
}

.edit-icon {
  font-size: 32rpx;
  opacity: 0.4;
  transition: opacity 0.2s ease;
}

.edit-btn-hover .edit-icon {
  opacity: 1;
}

/* 删除按钮 */
.delete-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.delete-btn-hover {
  background: #fef2f2;
  transform: scale(1.1);
}

.delete-icon {
  font-size: 32rpx;
  opacity: 0.4;
  transition: opacity 0.2s ease;
}

.delete-btn-hover .delete-icon {
  opacity: 1;
}

/* 浮动按钮 */
.fab-button {
  position: fixed;
  right: 32rpx;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  z-index: 100;
}

.fab-button:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.fab-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.plus-icon {
  color: #fff;
  font-size: 32rpx;
  font-weight: 300;
  line-height: 1;
}

.fab-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.fab-hover {
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.5);
}
