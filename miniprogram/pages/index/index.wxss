/**
 * TodoList 极简首页样式
 */

/* ==================== 页面布局 ==================== */

.page {
  min-height: 100vh;
  background-color: #F5F7FA;
  display: flex;
  flex-direction: column;
}

/* ==================== 顶部标题 ==================== */

.header {
  padding: 48rpx 32rpx 24rpx;
  background-color: #FFFFFF;
}

.header-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #1A1A1A;
  letter-spacing: -0.5rpx;
}

/* ==================== Focus 卡片 ==================== */

.focus-card {
  margin: 24rpx 32rpx;
  padding: 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.focus-subtitle {
  font-size: 28rpx;
  font-weight: 500;
  color: #666666;
}

.focus-desc {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

/* ==================== 任务列表 ==================== */

.task-list {
  flex: 1;
  padding: 0 32rpx;
  padding-bottom: 120rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  overflow-y: auto;
}

/* ==================== 空态 ==================== */

.empty-state {
  padding: 120rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999999;
}

/* ==================== 任务卡片 ==================== */

.task-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  gap: 16rpx;
  transition: all 0.2s ease;
}

.task-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.06);
}

.task-card.completed {
  opacity: 0.5;
}

.task-card.completed .task-title {
  text-decoration: line-through;
  color: #999999;
}

/* 任务配图占位符 */
.task-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background-color: #F5F7FA;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.task-icon {
  font-size: 40rpx;
  color: #4A90E2;
}

/* 任务内容 */
.task-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}

.task-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 操作按钮 */
.task-actions {
  display: flex;
  gap: 8rpx;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background-color: #F5F7FA;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.9);
  background-color: #EEEEEE;
}

.action-icon {
  font-size: 32rpx;
}

/* ==================== 底部按钮 ==================== */

.bottom-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  border-top: 1rpx solid #EEEEEE;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background-color: #4A90E2;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 226, 0.2);
  transition: all 0.2s ease;
}

.add-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(74, 144, 226, 0.15);
}

.add-icon {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

.add-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}
