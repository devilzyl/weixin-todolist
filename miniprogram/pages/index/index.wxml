<!-- TodoList 极简首页 -->
<view class="page">
  <!-- 顶部标题区域 -->
  <view class="header">
    <text class="header-title">My Tasks</text>
  </view>

  <!-- Today's Focus 区域 -->
  <view class="focus-card" wx:if="{{todos.length > 0}}">
    <text class="focus-subtitle">Today's Focus</text>
    <text class="focus-desc">You have {{pendingCount}} pending task{{pendingCount > 1 ? 's' : ''}}.</text>
  </view>

  <!-- 任务列表 -->
  <view class="task-list">
    <!-- 空态 -->
    <view wx:if="{{todos.length === 0}}" class="empty-state">
      <text class="empty-title">No tasks yet</text>
      <text class="empty-desc">Create your first task to get started</text>
    </view>

    <!-- 任务卡片 -->
    <view
      wx:for="{{todos}}"
      wx:key="id"
      class="task-card {{item.completed ? 'completed' : ''}}"
    >
      <!-- 任务配图占位符（点击切换状态） -->
      <view class="task-image" bindtap="handleToggle" data-id="{{item.id}}">
        <text class="task-icon">{{item.completed ? '✓' : '○'}}</text>
      </view>

      <!-- 任务内容 -->
      <view class="task-content" bindtap="handleToggle" data-id="{{item.id}}">
        <text class="task-title">{{item.title}}</text>
      </view>

      <!-- 操作按钮 -->
      <view class="task-actions">
        <view
          class="action-btn edit-btn"
          data-id="{{item.id}}"
          data-title="{{item.title}}"
          catchtap="navigateToEdit"
        >
          <text class="action-icon">✏️</text>
        </view>
        <view
          class="action-btn delete-btn"
          data-id="{{item.id}}"
          catchtap="handleDelete"
        >
          <text class="action-icon">🗑️</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部新增按钮（固定） -->
  <view class="bottom-action">
    <view class="add-btn" bindtap="navigateToCreate">
      <text class="add-icon">+</text>
      <text class="add-text">Add new task</text>
    </view>
  </view>
</view>
