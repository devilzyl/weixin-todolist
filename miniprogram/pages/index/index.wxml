<!-- TodoList 极简首页 -->
<view class="page">
  <!-- 顶部标题区域 -->
  <view class="header">
    <text class="header-title">我的任务</text>
  </view>

  <!-- 今日关注区域 -->
  <view class="focus-card" wx:if="{{todos.length > 0}}">
    <text class="focus-subtitle">今日关注</text>
    <text class="focus-desc">
      您有 {{pendingCount}} 个待办任务
      <text wx:if="{{highPriorityCount > 0}}" class="high-priority">
        （{{highPriorityCount}} 个高优先级）
      </text>
    </text>
  </view>

  <!-- 任务列表 -->
  <view class="task-list">
    <!-- 空态 -->
    <view wx:if="{{todos.length === 0}}" class="empty-state">
      <text class="empty-title">还没有任务</text>
      <text class="empty-desc">创建您的第一个任务开始使用</text>
    </view>

    <!-- 任务卡片 -->
    <swipe-card
      wx:for="{{todos}}"
      wx:key="id"
      class="task-card {{item.completed ? 'completed' : ''}}"
      todo-id="{{item.id}}"
      title="{{item.title}}"
      content="{{item.content}}"
      priority="{{item.priority}}"
      completed="{{item.completed}}"
      isExpanded="{{expandedId === item.id}}"
      bind:priority="handlePriority"
      bind:edit="navigateToEdit"
      bind:delete="handleDelete"
      bind:toggle-expand="toggleExpand"
      bind:toggle="handleToggleFromCard"
    />
  </view>

  <!-- 底部新增按钮（固定） -->
  <view class="bottom-action">
    <view class="add-btn" bindtap="navigateToCreate">
      <text class="add-icon">+</text>
      <text class="add-text">添加新任务</text>
    </view>
  </view>
</view>
