<!-- 任务编辑页面 -->
<view class="container">
  <view class="form" role="form" aria-label="编辑任务">
    <view class="form-item">
      <text class="label">任务标题</text>
      <textarea
        class="textarea"
        placeholder="请输入任务标题（1-100字）"
        value="{{title}}"
        bindinput="onInputChange"
        maxlength="100"
        auto-height
        aria-label="任务标题输入框"
        required
      />
      <text class="counter" aria-label="已输入{{titleLength}}字，最多100字">{{titleLength}}/100</text>
    </view>
  </view>

  <view class="actions">
    <button
      class="cancel-button"
      bindtap="handleCancel"
      aria-label="取消编辑"
    >
      取消
    </button>
    <button
      class="save-button {{isSubmitting ? 'disabled' : ''}}"
      bindtap="handleSave"
      disabled="{{isSubmitting}}"
      aria-label="保存修改"
    >
      保存
    </button>
  </view>
</view>
