/**
 * 任务编辑页面 - 极简样式
 */

.container {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding: 24rpx 32rpx;
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

/* 表单卡片 */
.form {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  font-weight: 500;
  color: #666666;
}

/* 标题行 */
.title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.title-input {
  flex: 1;
  padding: 16rpx 20rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 16rpx;
  font-size: 32rpx;
  background-color: #FAFAFA;
  color: #1A1A1A;
  transition: all 0.2s ease;
}

.title-input:focus {
  border-color: #4A90E2;
  background-color: #FFFFFF;
}

/* 优先级选择器 */
.priority-selector {
  width: 140rpx;
  flex-shrink: 0;
}

.priority-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 16rpx;
  background-color: #FAFAFA;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s ease;
}

.priority-picker:active {
  background-color: #F0F0F0;
}

/* 优先级色点 */
.priority-dot-low,
.priority-dot-medium,
.priority-dot-high {
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.priority-dot-low {
  background-color: #8E8E93;
}

.priority-dot-medium {
  background-color: #007AFF;
}

.priority-dot-high {
  background-color: #FF3B30;
}

.priority-label {
  font-size: 28rpx;
  font-weight: 500;
}

/* 内容输入框 */
.content-input {
  width: 100%;
  min-height: 160rpx;
  max-height: 400rpx;
  padding: 20rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 16rpx;
  font-size: 28rpx;
  background-color: #FAFAFA;
  color: #1A1A1A;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.content-input:focus {
  border-color: #4A90E2;
  background-color: #FFFFFF;
}

.counter {
  align-self: flex-end;
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

/* 操作按钮 */
.actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #F5F7FA;
  display: flex;
  gap: 16rpx;
}

.cancel-button,
.save-button {
  flex: 1;
  padding: 24rpx 32rpx;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.cancel-button {
  background-color: #FFFFFF;
  color: #666666;
  border: 2rpx solid #E5E5E5;
}

.cancel-button:active {
  background-color: #F5F7FA;
}

.save-button {
  background-color: #4A90E2;
  color: #FFFFFF;
  border: none;
}

.save-button:active {
  background-color: #3A7BC8;
}

.save-button.disabled {
  background-color: #E5E5E5;
  color: #999999;
}

.save-button::after {
  border: none;
}
