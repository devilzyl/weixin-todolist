/**
 * 新增任务页面 - 极简样式
 */

.container {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
}

/* 表单卡片 */
.form {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 500;
  color: #666666;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 16rpx;
  font-size: 32rpx;
  background-color: #FAFAFA;
  color: #1A1A1A;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.textarea:focus {
  border-color: #4A90E2;
  background-color: #FFFFFF;
}

.counter {
  align-self: flex-end;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 操作按钮 */
.actions {
  display: flex;
  gap: 16rpx;
  margin-top: auto;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.cancel-button,
.save-button {
  flex: 1;
  padding: 32rpx;
  min-height: 88rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.cancel-button {
  background-color: #FFFFFF;
  color: #666666;
  border: 2rpx solid #E5E5E5;
}

.cancel-button:active {
  background-color: #F5F7FA;
}

.save-button {
  background-color: #4A90E2;
  color: #FFFFFF;
  border: none;
}

.save-button:active {
  background-color: #3A7BC8;
}

.save-button.disabled {
  background-color: #E5E5E5;
  color: #999999;
}

.save-button::after {
  border: none;
}
