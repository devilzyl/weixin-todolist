<!-- 滑动卡片组件 -->
<view class="swipe-area">
  <view class="action-buttons">
    <view
      class="action-btn edit-btn"
      catchtap="onEdit"
      data-id="{{todoId}}"
    >
      <text class="action-text">编辑</text>
    </view>
    <view
      class="action-btn delete-btn"
      catchtap="onDelete"
      data-id="{{todoId}}"
    >
      <text class="action-text">删除</text>
    </view>
  </view>

  <view
    class="swipe-content"
    style="transform: translateX({{translateX}}px);"
    bindtouchstart="onTouchStart"
    bindtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
    bindtouchcancel="onTouchEnd"
  >
    <!-- 任务标题行 -->
    <view class="todo-header">
      <!-- 完成状态复选框 -->
      <view class="todo-checkbox {{completed ? 'checked' : ''}}" catchtap="onIconTap">
        <view class="checkbox-icon" wx:if="{{completed}}">✓</view>
      </view>

      <!-- 优先级色点 -->
      <priority-dot
        todo-id="{{todoId}}"
        priority="{{priority}}"
        bind:cycle="handlePriority"
      />

      <!-- 任务标题 -->
      <text class="todo-title {{completed ? 'completed-title' : ''}}">{{title}}</text>
    </view>

    <!-- 任务内容行 -->
    <view
      wx:if="{{content}}"
      class="todo-content {{isExpanded ? 'expanded' : ''}}"
      catchtap="onCardTap"
    >
      <text class="content-text">
        {{isExpanded ? content : truncatedContent}}
      </text>
      <text
        wx:if="{{showExpandHint}}"
        class="expand-hint"
      >
        {{isExpanded ? '...收起' : '...展开'}}
      </text>
    </view>
  </view>
</view>
