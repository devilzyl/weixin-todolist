/**
 * 滑动卡片组件样式
 */

.swipe-area {
  position: relative;
  width: 100%;
  height: 100%;
}

.swipe-content {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 100%;
  background-color: #FFFFFF;
}

.action-buttons {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  z-index: 1;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.priority-btn {
  background-color: #4A90E2;
  color: #FFFFFF;
}

.edit-btn {
  background-color: #FFA500;
  color: #FFFFFF;
}

.delete-btn {
  background-color: #FF4D4F;
  color: #FFFFFF;
}
