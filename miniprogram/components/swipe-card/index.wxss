/**
 * 滑动卡片组件样式
 */

.swipe-area {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.swipe-content {
  position: relative;
  z-index: 2;
  width: 100%;
  padding: 28rpx 24rpx;
  background-color: #FFFFFF;
  display: flex;
  flex-direction: column;
}

/* 任务标题行 */
.todo-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

/* 完成状态复选框 */
.todo-checkbox {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  margin-right: 8rpx;
  border: 3rpx solid #D9D9D9;
  border-radius: 8rpx;
  background-color: #FFFFFF;
  cursor: pointer;
  transition: all 0.2s ease;
}

.todo-checkbox.checked {
  background-color: #1890FF;
  border-color: #1890FF;
}

.checkbox-icon {
  font-size: 28rpx;
  font-weight: bold;
  color: #FFFFFF;
  line-height: 1;
}

.todo-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition: all 0.2s ease;
}

.todo-title.completed-title {
  color: #999999;
  text-decoration: line-through;
}

/* 任务内容行 */
.todo-content {
  margin-bottom: 16rpx;
  margin-left: 60rpx;
  line-height: 1.6;
  cursor: pointer;
  padding-top: 4rpx;
}

.content-text {
  font-size: 28rpx;
  color: #666;
  word-break: break-all;
}

/* 内容最多显示2行 */
.todo-content:not(.expanded) .content-text {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 展开提示 */
.expand-hint {
  color: #007AFF;
  font-size: 24rpx;
  margin-left: 8rpx;
}

/* 按钮区域 */
.action-buttons {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  z-index: 1;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.edit-btn {
  background-color: #FFA500;
  color: #FFFFFF;
}

.delete-btn {
  background-color: #FF4D4F;
  color: #FFFFFF;
}
