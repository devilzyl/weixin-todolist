<!-- 任务表单组件 -->
<view class="task-form">
  <!-- 标题输入 -->
  <view class="form-item">
    <text class="form-label">标题</text>
    <input
      class="form-input"
      placeholder="请输入任务标题"
      value="{{title}}"
      bindinput="onTitleInput"
      maxlength="50"
    />
  </view>

  <!-- 描述输入 -->
  <view class="form-item">
    <text class="form-label">描述</text>
    <textarea
      class="form-textarea"
      placeholder="请输入任务描述（可选）"
      value="{{content}}"
      bindinput="onContentInput"
      maxlength="500"
      auto-height
    />
  </view>

  <!-- 分类选择 -->
  <view class="form-item">
    <text class="form-label">分类</text>
    <view class="option-group">
      <view
        class="option-btn {{category === 'work' ? 'active' : ''}}"
        data-value="work"
        bindtap="onCategoryChange"
      >
        工作
      </view>
      <view
        class="option-btn {{category === 'personal' ? 'active' : ''}}"
        data-value="personal"
        bindtap="onCategoryChange"
      >
        个人
      </view>
      <view
        class="option-btn {{category === 'default' ? 'active' : ''}}"
        data-value="default"
        bindtap="onCategoryChange"
      >
        默认
      </view>
    </view>
  </view>

  <!-- 优先级选择 -->
  <view class="form-item">
    <text class="form-label">优先级</text>
    <view class="option-group">
      <view
        class="option-btn priority-high {{priority === 'high' ? 'active' : ''}}"
        data-value="high"
        bindtap="onPriorityChange"
      >
        高
      </view>
      <view
        class="option-btn priority-medium {{priority === 'medium' ? 'active' : ''}}"
        data-value="medium"
        bindtap="onPriorityChange"
      >
        中
      </view>
      <view
        class="option-btn priority-low {{priority === 'low' ? 'active' : ''}}"
        data-value="low"
        bindtap="onPriorityChange"
      >
        低
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <button class="save-btn" bindtap="onSave">保存</button>
</view>
