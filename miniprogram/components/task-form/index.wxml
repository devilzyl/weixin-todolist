<!-- 任务表单组件 -->
<view class="task-form {{theme === 'dark' ? 'dark' : ''}}">
  <!-- 标题输入 -->
  <view class="form-item">
    <text class="form-label">任务名称</text>
    <input
      class="form-input"
      placeholder="输入任务名称..."
      value="{{title}}"
      bindinput="onTitleInput"
      maxlength="50"
    />
  </view>

  <!-- 分类选择 -->
  <view class="form-item">
    <text class="form-label">标签</text>
    <view class="option-group">
      <view
        class="option-btn tag-work {{category === 'work' ? 'active' : ''}}"
        data-value="work"
        bindtap="onCategoryChange"
      >
        工作
      </view>
      <view
        class="option-btn tag-personal {{category === 'personal' ? 'active' : ''}}"
        data-value="personal"
        bindtap="onCategoryChange"
      >
        个人
      </view>
    </view>
  </view>

  <!-- 优先级选择 -->
  <view class="form-item">
    <text class="form-label">优先级</text>
    <view class="option-group">
      <view
        class="option-btn priority-high {{priority === 'high' ? 'active' : ''}}"
        data-value="high"
        bindtap="onPriorityChange"
      >
        高
      </view>
      <view
        class="option-btn priority-medium {{priority === 'medium' ? 'active' : ''}}"
        data-value="medium"
        bindtap="onPriorityChange"
      >
        中
      </view>
      <view
        class="option-btn priority-low {{priority === 'low' ? 'active' : ''}}"
        data-value="low"
        bindtap="onPriorityChange"
      >
        低
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <button class="save-btn" bindtap="onSave">{{todo ? '保存修改' : '添加任务'}}</button>
</view>
