/* 任务表单组件样式 - Apple 风格 */

.task-form {
  padding: 0;
}

/* 表单项 */
.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: #86868b;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  margin-bottom: 16rpx;
}

/* 输入框 */
.form-input {
  width: 100%;
  padding: 28rpx 32rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  background: rgba(255, 255, 255, 0.6);
  font-size: 30rpx;
  font-family: inherit;
  color: #1d1d1f;
  transition: all 0.25s ease;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #86868b;
}

.form-input:focus {
  border-color: #007aff;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 0 0 6rpx rgba(0, 122, 255, 0.15);
}

/* 文本域 */
.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 28rpx 32rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  background: rgba(255, 255, 255, 0.6);
  font-size: 30rpx;
  font-family: inherit;
  color: #1d1d1f;
  box-sizing: border-box;
  transition: all 0.25s ease;
}

.form-textarea::placeholder {
  color: #86868b;
}

.form-textarea:focus {
  border-color: #007aff;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 0 0 6rpx rgba(0, 122, 255, 0.15);
}

/* 选项组 */
.option-group {
  display: flex;
  gap: 16rpx;
}

/* 标签选项按钮 */
.option-btn {
  flex: 1;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  background: rgba(255, 255, 255, 0.4);
  font-size: 26rpx;
  font-weight: 500;
  color: #86868b;
  text-align: center;
  transition: all 0.25s ease;
}

.option-btn.active {
  border-color: transparent;
}

.option-btn.tag-work.active {
  background: rgba(255, 149, 0, 0.15);
  color: #ff9500;
}

.option-btn.tag-personal.active {
  background: rgba(0, 122, 255, 0.12);
  color: #007aff;
}

/* 优先级选项按钮 */
.option-btn.priority-high.active {
  background: rgba(255, 59, 48, 0.12);
  color: #ff3b30;
}

.option-btn.priority-medium.active {
  background: rgba(255, 149, 0, 0.12);
  color: #ff9500;
}

.option-btn.priority-low.active {
  background: rgba(52, 199, 89, 0.12);
  color: #34c759;
}

/* 保存按钮 */
.save-btn {
  width: 100%;
  padding: 24rpx 40rpx;
  border-radius: 24rpx;
  border: none;
  background: linear-gradient(135deg, #007aff, #0051d4);
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  margin-top: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 122, 255, 0.3);
  transition: all 0.25s ease;
}

.save-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 122, 255, 0.4);
}

.save-btn:active {
  transform: translateY(0);
  box-shadow: 0 4rpx 16rpx rgba(0, 122, 255, 0.3);
}

/* 暗色模式 */
.task-form.dark .form-label {
  color: #a1a1a6;
}

.task-form.dark .form-input,
.task-form.dark .form-textarea {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.12);
  color: #f5f5f7;
}

.task-form.dark .form-input::placeholder,
.task-form.dark .form-textarea::placeholder {
  color: #a1a1a6;
}

.task-form.dark .form-input:focus,
.task-form.dark .form-textarea:focus {
  background: rgba(255, 255, 255, 0.12);
  border-color: #0a84ff;
  box-shadow: 0 0 0 6rpx rgba(10, 132, 255, 0.2);
}

.task-form.dark .option-btn {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(255, 255, 255, 0.1);
  color: #a1a1a6;
}

.task-form.dark .option-btn.tag-work.active {
  background: rgba(255, 149, 0, 0.2);
}

.task-form.dark .option-btn.tag-personal.active {
  background: rgba(10, 132, 255, 0.2);
}

.task-form.dark .option-btn.priority-high.active {
  background: rgba(255, 59, 48, 0.2);
}

.task-form.dark .option-btn.priority-medium.active {
  background: rgba(255, 149, 0, 0.2);
}

.task-form.dark .option-btn.priority-low.active {
  background: rgba(52, 199, 89, 0.2);
}

.task-form.dark .save-btn {
  background: linear-gradient(135deg, #0a84ff, #0066cc);
  box-shadow: 0 8rpx 24rpx rgba(10, 132, 255, 0.3);
}

.task-form.dark .save-btn:hover {
  box-shadow: 0 12rpx 32rpx rgba(10, 132, 255, 0.4);
}

.task-form.dark .save-btn:active {
  box-shadow: 0 4rpx 16rpx rgba(10, 132, 255, 0.3);
}
