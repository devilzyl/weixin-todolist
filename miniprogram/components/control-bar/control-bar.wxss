/* 控制栏样式 */
.control-bar {
  display: flex;
  align-items: center;
  margin: 0 32rpx 24rpx 32rpx;
  padding: 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  gap: 16rpx;
}

/* 控制项样式 */
.control-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 24rpx;
  background: #F5F7FA;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  gap: 16rpx;
}

/* 标签样式 */
.control-label {
  color: #666;
  font-size: 28rpx;
}

/* 值样式 */
.control-value {
  color: #1A1A1A;
  font-weight: 600;
}

/* 箭头图标样式 */
.picker-icon {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: #999;
}
