/* 控制栏样式 */
.control-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
  gap: 24rpx;
}

/* 控制项样式 */
.control-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

/* 标签样式 */
.control-label {
  color: #666;
  font-size: 28rpx;
}

/* 值样式 */
.control-value {
  color: #333;
  font-weight: 500;
}

/* 箭头图标样式 */
.picker-icon {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: #999;
}
