/**
 * 全局样式 - 极简设计
 */

/* ==================== 全局重置 ==================== */

page {
  height: 100vh;
  background-color: #F5F7FA;
  color: #1A1A1A;
  font-size: 32rpx;
  line-height: 1.5;
}

/* 去除默认按钮样式 */
button {
  margin: 0;
  padding: 0;
  border: none;
  background: none;
  font-size: inherit;
  line-height: inherit;
}

button::after {
  border: none;
}

/* ==================== 全局页面容器 ==================== */

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #F5F7FA;
}

/* ==================== 全局容器 ==================== */

.main-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 32rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}
