/**
 * 全局样式
 */

/* ==================== 全局重置 ==================== */

page {
  height: 100vh;
  background-color: #f9fafb;
  color: #1f2937;
  font-size: 30rpx;
  line-height: 1.5;
}

/* 去除默认按钮样式 */
button {
  margin: 0;
  padding: 0;
  border: none;
  background: none;
  font-size: inherit;
  line-height: inherit;
}

button::after {
  border: none;
}

/* ==================== 全局容器 ==================== */

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}
